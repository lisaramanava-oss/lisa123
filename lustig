<script>
function lk(btn){
  btn.classList.toggle('liked');
  const c=btn.querySelector('.ec');
  let t=c.textContent.trim();
  const isK=t.endsWith('K'), isM=t.endsWith('M');
  let n=parseFloat(t.replace(/[KM,]/g,'').replace('.','').replace(',','.'));
  if(isM) n=Math.round(n*1000000);
  else if(isK) n=Math.round(n*1000);
  n+=btn.classList.contains('liked')?1:-1;
  if(n>=1000000) c.textContent=(n/1000000).toFixed(1)+'M';
  else if(n>=1000) c.textContent=(n/1000).toFixed(1).replace(/\.0$/,'')+'K';
  else c.textContent=n.toLocaleString('de');
  btn.querySelector('.ei').textContent=btn.classList.contains('liked')?'❤️':'🤍';
}

function filt(tag,btn){
  document.querySelectorAll('.fb').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.post').forEach(p=>{
    if(tag==='all'){p.style.display='';return;}
    p.style.display=(p.dataset.tags||'').split(' ').includes(tag)?'':'none';
  });
  document.querySelectorAll('.div').forEach(d=>d.style.display=tag==='all'?'':'none');
  document.querySelectorAll('.strip').forEach(s=>s.style.display=tag==='all'?'':'s'.includes(tag)?'':'');
}

function vote(opt,total){
  const poll=opt.closest('.poll');
  if(poll.dataset.voted) return;
  poll.dataset.voted='1';
  const opts=poll.querySelectorAll('.popt');
  const pcts=[11,18,24,47];
  opts.forEach((o,i)=>{
    const np=i===Array.from(opts).indexOf(opt)?pcts[i]+1:pcts[i];
    o.querySelector('.pbar').style.width=np+'%';
    o.querySelector('.ppc').textContent=np+'%';
    o.style.cursor='default';
  });
}
</script>

