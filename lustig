<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,700;1,400&family=IBM+Plex+Mono:wght@400;500;700&display=swap');

*{margin:0;padding:0;box-sizing:border-box;}

:root{
--bg:#eeebe5;
--card:#fff;
--text:#111;
--muted:#888;
--g:#00A86B;
--r:#e63946;
--border:#dedad3;
--tbg:#edf9f4;
--tc:#007a50;
--y:#f5c400;
--dark:#1a1a1a;
}

body{font-family:'IBM Plex Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding-bottom:90px;}

/* ── NAV ── */
nav{background:#fff;border-bottom:2.5px solid #111;padding:12px 20px;display:flex;align-items:center;gap:10px;position:sticky;top:0;z-index:300;}
.logo{display:flex;align-items:center;gap:9px;text-decoration:none;}
.lm{width:34px;height:34px;background:var(--g);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:17px;color:#fff;font-weight:900;}
.ln{font-weight:800;font-size:19px;letter-spacing:-.5px;color:#111;}
.ln b{color:var(--g);}
.npill{font-family:'IBM Plex Mono',monospace;font-size:9px;background:#111;color:#fff;padding:3px 8px;border-radius:3px;letter-spacing:.1em;}
.nright{margin-left:auto;font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--muted);}

/* ── HERO ── */
.hero{background:var(--dark);color:#fff;padding:40px 20px 32px;text-align:center;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 60% 40%,rgba(0,168,107,.15) 0%,transparent 70%);pointer-events:none;}
.hk{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.18em;color:var(--g);margin-bottom:14px;text-transform:uppercase;}
.hero h1{font-size:clamp(26px,6vw,56px);font-weight:800;line-height:1.05;letter-spacing:-2px;max-width:600px;margin:0 auto 14px;}
.hero h1 i{font-style:italic;color:var(--g);font-weight:400;}
.hsub{font-family:'IBM Plex Mono',monospace;font-size:10px;color:#444;letter-spacing:.05em;}
.hstats{display:flex;justify-content:center;gap:32px;margin-top:24px;flex-wrap:wrap;}
.hstat{text-align:center;}
.hstat-n{font-size:22px;font-weight:800;color:var(--g);}
.hstat-l{font-family:'IBM Plex Mono',monospace;font-size:9px;color:#555;letter-spacing:.08em;margin-top:2px;}

/* ── TICKER ── */
.ticker{background:var(--g);color:#fff;padding:7px 0;overflow:hidden;white-space:nowrap;}
.ticker-inner{display:inline-block;animation:tick 30s linear infinite;font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.08em;}
@keyframes tick{from{transform:translateX(100vw)}to{transform:translateX(-100%)}}

/* ── FILTERS ── */
.filters{background:#fff;border-bottom:1px solid var(--border);padding:11px 16px;display:flex;gap:7px;overflow-x:auto;scrollbar-width:none;position:sticky;top:59px;z-index:200;}
.filters::-webkit-scrollbar{display:none;}
.fb{font-family:'IBM Plex Mono',monospace;font-size:10px;padding:5px 13px;border:1.5px solid var(--border);border-radius:20px;background:#fff;color:var(--muted);cursor:pointer;white-space:nowrap;transition:.12s;}
.fb:hover,.fb.active{background:#111;color:#fff;border-color:#111;}

/* ── FEED ── */
.feed{max-width:600px;margin:0 auto;padding:20px 12px;display:flex;flex-direction:column;gap:13px;}

/* ── POST ── */
.post{background:#fff;border:1.5px solid var(--border);border-radius:13px;overflow:hidden;transition:transform .15s,box-shadow .15s;animation:up .35s ease both;}
.post:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(0,0,0,.09);}
@keyframes up{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* strips */
.strip{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.1em;padding:5px 16px;text-transform:uppercase;}
.strip.gr{background:var(--g);color:#fff;}
.strip.rd{background:var(--r);color:#fff;}
.strip.yl{background:var(--y);color:#111;}
.strip.dk{background:#111;color:var(--g);}

/* header */
.ph{padding:13px 15px 0;display:flex;align-items:flex-start;gap:10px;}
.av{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;color:#fff;flex-shrink:0;border:2px solid var(--border);}
.av.g{background:var(--g);}
.av.r{background:var(--r);}
.av.d{background:#222;}
.av.b{background:#0055cc;}
.av.o{background:#d97000;}
.av.p{background:#7700cc;}
.av.s{background:#006699;}
.av.t{background:#1da1f2;}
.av.pi{background:#cc0066;}
.av.w{background:#25d366;}
.pm{flex:1;min-width:0;}
.pn{font-weight:700;font-size:13.5px;line-height:1.2;}
.pr{font-family:'IBM Plex Mono',monospace;font-size:9.5px;color:var(--muted);margin-top:1px;}
.ptag{font-family:'IBM Plex Mono',monospace;font-size:8.5px;padding:2px 7px;border:1px solid var(--border);border-radius:3px;color:var(--muted);letter-spacing:.04em;text-transform:uppercase;white-space:nowrap;}

/* body */
.pb{padding:12px 15px;font-size:14.5px;line-height:1.62;color:var(--text);}
.pb .st{text-decoration:line-through;color:var(--muted);}
.pb .gn{color:var(--g);font-weight:700;}
.pb .rd{color:var(--r);}
.pb .bld{font-weight:700;}
.pb a{color:var(--g);text-decoration:none;}

/* meme visual */
.mv{margin:0 15px 6px;border-radius:9px;overflow:hidden;border:1.5px solid var(--border);}
.mbox{background:#111;padding:22px 18px;text-align:center;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:9px;min-height:120px;}
.mt{font-family:'IBM Plex Mono',monospace;font-size:9.5px;color:#555;letter-spacing:.12em;text-transform:uppercase;}
.mm{font-size:clamp(16px,3.5vw,24px);font-weight:800;color:#fff;line-height:1.25;max-width:340px;}
.mm .gg{color:var(--g);}
.mm .yy{color:var(--y);}
.mb{font-family:'IBM Plex Mono',monospace;font-size:9px;color:#3a3a3a;}

/* organ grid */
.obox{background:#0c1a10;padding:18px 16px;display:grid;grid-template-columns:1fr 1fr;gap:9px;margin:0 15px 6px;border-radius:9px;border:1.5px solid #1a3a22;}
.org{background:#0a2416;border:1px solid #1a3a22;border-radius:7px;padding:11px 10px;text-align:center;}
.oi{font-size:24px;line-height:1;margin-bottom:3px;}
.on{font-family:'IBM Plex Mono',monospace;font-size:8px;color:var(--g);letter-spacing:.1em;text-transform:uppercase;}
.os{font-size:13px;font-weight:800;color:#fff;margin-top:2px;}
.oc{font-size:9.5px;color:#444;margin-top:1px;}

/* stat rows */
.srow{background:var(--tbg);padding:13px 18px;display:grid;gap:10px;text-align:center;border-top:1px solid #d0ead8;}
.srow.g2{grid-template-columns:1fr 1fr;}
.srow.g3{grid-template-columns:1fr 1fr 1fr;}
.srow.g4{grid-template-columns:1fr 1fr 1fr 1fr;}
.sn{font-size:20px;font-weight:800;color:var(--g);line-height:1;}
.sl{font-family:'IBM Plex Mono',monospace;font-size:8px;color:var(--muted);letter-spacing:.07em;text-transform:uppercase;margin-top:2px;}

/* reply */
.rpl{margin:0 15px 8px;background:#f6f4f0;border-left:3px solid var(--g);padding:9px 12px;border-radius:0 7px 7px 0;font-size:13px;color:#555;font-style:italic;line-height:1.5;}
.rpl-n{font-style:normal;font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--muted);font-weight:700;margin-bottom:3px;}

/* tags */
.tags{padding:0 15px 9px;display:flex;flex-wrap:wrap;gap:5px;}
.tag{background:var(--tbg);color:var(--tc);font-size:9.5px;font-family:'IBM Plex Mono',monospace;padding:2px 8px;border-radius:3px;border:1px solid #b8e2cf;}

/* engagement */
.eng{padding:8px 15px 12px;border-top:1px solid var(--border);display:flex;align-items:center;gap:16px;margin-top:2px;}
.eb{display:flex;align-items:center;gap:4px;font-size:11.5px;color:var(--muted);cursor:pointer;background:none;border:none;font-family:'IBM Plex Sans',sans-serif;padding:0;transition:.12s;user-select:none;}
.eb:hover{color:#111;}
.eb.liked{color:var(--r);}
.ei{font-size:15px;transition:transform .15s;display:inline-block;}
.ec{font-family:'IBM Plex Mono',monospace;font-size:10.5px;}
.ml{margin-left:auto;}

/* divider */
.div{text-align:center;font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--muted);letter-spacing:.12em;display:flex;align-items:center;gap:10px;padding:2px 0;}
.div::before,.div::after{content:'';flex:1;height:1px;background:var(--border);}

/* quote card */
.qcard{margin:0 15px 8px;background:#f6f4f0;border:1.5px solid var(--border);border-radius:9px;padding:11px 13px;font-size:13px;color:#555;line-height:1.5;}
.qcard-name{font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--muted);font-weight:700;margin-bottom:4px;}

/* poll */
.poll{margin:0 15px 8px;display:flex;flex-direction:column;gap:7px;}
.popt{background:#f6f4f0;border:1.5px solid var(--border);border-radius:7px;padding:9px 13px;font-size:13px;cursor:pointer;transition:.12s;position:relative;overflow:hidden;}
.popt:hover{border-color:var(--g);}
.popt .pbar{position:absolute;left:0;top:0;bottom:0;background:#edf9f4;z-index:0;transition:width .4s;}
.popt span{position:relative;z-index:1;font-weight:500;}
.popt .ppc{position:absolute;right:10px;top:50%;transform:translateY(-50%);font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--muted);z-index:1;}

/* ── BOTTOM BAR ── */
.bot{position:fixed;bottom:0;left:0;right:0;background:#111;color:#fff;padding:11px 20px;display:flex;align-items:center;gap:12px;z-index:200;border-top:2.5px solid var(--g);}
.bt{font-size:12px;line-height:1.4;}
.bt strong{color:var(--g);}
.bt span{color:#555;font-size:9px;font-family:'IBM Plex Mono',monospace;display:block;}
.bcta{margin-left:auto;background:var(--g);color:#fff;border:none;padding:9px 18px;border-radius:7px;font-weight:700;font-size:12px;cursor:pointer;font-family:'IBM Plex Sans',sans-serif;white-space:nowrap;}
</style>

